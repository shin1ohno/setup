{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ruby .claude/hooks/guard-mitamae-dry-run.rb"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ruby .claude/hooks/remind-cookbook-dry-run.rb"
          }
        ]
      }
    ]
  }
}
