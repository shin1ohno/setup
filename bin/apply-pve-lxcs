#!/usr/bin/env bash
# bin/apply-pve-lxcs — apply pve/lxc-<host>.rb to all PVE-virtualized
# LXCs in parallel via SSH.
#
# Assumes:
#   - SSH alias for each host resolves (Tailscale Magic DNS or local DNS)
#   - shared setup repo at REPO_PATH on each target (default /root/setup)
#   - passwordless sudo for the SSH user on each LXC
#
# Usage:
#   bin/apply-pve-lxcs                    # all 11 LXCs in parallel
#   bin/apply-pve-lxcs cognee hydra       # subset only
#   PARALLEL_JOBS=2 bin/apply-pve-lxcs    # cap concurrency
#   REPO_PATH=/opt/setup bin/apply-pve-lxcs

set -euo pipefail

REPO_PATH="${REPO_PATH:-/root/setup}"
PARALLEL_JOBS="${PARALLEL_JOBS:-4}"

declare -a hosts=(
  cognee
  consent
  housekeeping
  hydra
  memory
  pro-dev
  pro-router
  roon
  roon-mcp
  samba
  weave
)
[ "$#" -gt 0 ] && hosts=("$@")

apply_one() {
  local host=$1
  local recipe="pve/lxc-${host}.rb"
  ssh -o BatchMode=yes "${host}" \
    "sudo -n bash -c 'set -euo pipefail; cd ${REPO_PATH} && git pull --ff-only && ./bin/setup && ./bin/mitamae local ${recipe}'"
}
export -f apply_one
export REPO_PATH

if command -v parallel >/dev/null 2>&1; then
  printf '%s\n' "${hosts[@]}" \
    | parallel -j "${PARALLEL_JOBS}" --line-buffer --tag apply_one {}
else
  for h in "${hosts[@]}"; do
    printf '==> %s\n' "$h"
    apply_one "$h"
  done
fi
