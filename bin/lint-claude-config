#!/usr/bin/env bash
set -euo pipefail

errors=0

echo "=== Claude Code Configuration Lint ==="

# 1. JSON syntax check
for f in ~/.claude/settings.json ~/.claude/settings.local.json; do
  if [[ -f "$f" ]]; then
    if ! jq . "$f" > /dev/null 2>&1; then
      echo "ERROR: Invalid JSON: $f"
      errors=$((errors + 1))
    else
      echo "OK: JSON syntax valid: $f"
    fi
  fi
done

# 2. Denylist completeness
for pattern in "Bash(rm -rf:*)" "Bash(rm -r :*)"; do
  if ! jq -e --arg p "$pattern" '.permissions.deny | index($p)' ~/.claude/settings.json > /dev/null 2>&1; then
    echo "WARN: '$pattern' missing from denylist in ~/.claude/settings.json"
    errors=$((errors + 1))
  fi
done
echo "OK: Denylist checked"

echo ""
echo "=== Lint complete. Issues: $errors ==="
exit "$errors"
