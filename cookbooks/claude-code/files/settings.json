{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(npm install:*)",
      "Bash(pnpm install:*)",
      "Bash(npm test:*)",
      "Bash(npm run :*)",
      "Bash(npx :*)",
      "Bash(bundle exec :*)",
      "Bash(make :*)",
      "Bash(gh pr :*)",
      "Bash(rm :*)",
      "Bash(ls :*)",
      "Bash(cat :*:*)",
      "Bash(osascript -e:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r :*)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ruby ~/.claude/hooks/pre-commit-test.rb"
          },
          {
            "type": "command",
            "command": "ruby ~/.claude/hooks/block-co-authored-by.rb"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send --urgency=low 'Claude Code' 'Waiting for input' 2>/dev/null; true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ruby ~/.claude/hooks/check-trailing-newline.rb"
          },
          {
            "type": "command",
            "command": "ruby ~/.claude/hooks/check-whitespace-lines.rb"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "ruby ~/.claude/hooks/post-compact-remind.rb"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "enableAllProjectMcpServers": true,
  "skipDangerousModePermissionPrompt": true
}
