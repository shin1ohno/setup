{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(npm install:*)",
      "Bash(pnpm install:*)",
      "Bash(npm test:*)",
      "Bash(npm run :*)",
      "Bash(npx :*)",
      "Bash(bundle exec :*)",
      "Bash(make :*)",
      "Bash(gh pr :*)",
      "Bash(rm :*)",
      "Bash(ls :*)",
      "Bash(cat :*:*)",
      "Bash(osascript -e:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r :*)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pre-commit-test.py"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "enableAllProjectMcpServers": true,
  "skipDangerousModePermissionPrompt": true
}
