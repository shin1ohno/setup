# --- LLM via OpenAI direct API ---
# Cognee talks directly to api.openai.com (no proxy in front).
# Replace LLM_API_KEY with your personal OpenAI API key before starting.
LLM_PROVIDER=openai
# Prefix with "openai/" to make instructor/litellm pick the OpenAI client
# (avoids any provider auto-detection from the model name).
LLM_MODEL=openai/gpt-4o
LLM_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=sk-openai-personal-key

# --- Embedding via OpenAI direct API ---
# Host CPUs without AVX2 cannot run fastembed/onnxruntime, so a remote
# provider is required. Reuse the same LLM_API_KEY here.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_ENDPOINT=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-openai-personal-key
EMBEDDING_DIMENSIONS=1536

# --- Storage backends ---
# chromadb is used because lancedb requires AVX2 CPU instructions.
GRAPH_DATABASE_PROVIDER=kuzu
VECTOR_DB_PROVIDER=chromadb

# --- OAuth2 Proxy ---
OAUTH2_CLIENT_SECRET=<hydra-client-secret>
OAUTH2_COOKIE_SECRET=<oauth2-proxy-cookie-secret>

# --- Cognee MCP ---
COGNEE_MCP_API_TOKEN=<cognee-api-jwt-token>
