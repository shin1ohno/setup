# --- LLM via existing litellm proxy ---
# The litellm proxy exposes an OpenAI-compatible API surface.
# Replace LLM_ENDPOINT and LLM_API_KEY with your proxy's values before starting.
LLM_PROVIDER=openai
# Prefix with "openai/" so litellm routes via the OpenAI provider
# (hitting LLM_ENDPOINT) instead of auto-detecting Anthropic from the name.
LLM_MODEL=openai/claude-sonnet-4-6
LLM_ENDPOINT=https://your-litellm-proxy.example.com/v1
LLM_API_KEY=sk-litellm-master-key

# --- Embedding via the same litellm proxy ---
# Host CPUs without AVX2 cannot run fastembed/onnxruntime, so we proxy
# embeddings through litellm too. Set EMBEDDING_API_KEY to the same key.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_ENDPOINT=https://your-litellm-proxy.example.com/v1
EMBEDDING_API_KEY=sk-litellm-master-key
EMBEDDING_DIMENSIONS=1536

# --- Storage backends ---
# chromadb is used because lancedb requires AVX2 CPU instructions.
GRAPH_DATABASE_PROVIDER=kuzu
VECTOR_DB_PROVIDER=chromadb

# --- OAuth2 Proxy ---
OAUTH2_CLIENT_SECRET=<hydra-client-secret>
OAUTH2_COOKIE_SECRET=<oauth2-proxy-cookie-secret>

# --- Cognee MCP ---
COGNEE_MCP_API_TOKEN=<cognee-api-jwt-token>
