{
  "which_key": {
    "enabled": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "buffer_font_size": 15.0,
  "text_rendering_mode": "subpixel",
  "ui_font_family": "SauceCodePro Nerd Font Mono",
  "buffer_line_height": "comfortable",
  "icon_theme": "Catppuccin Frappé",
  "code_lens": "on",
  "edit_predictions": {
    "ollama": {
      "model": "qwen2.5-coder:7b-base",
    },
    "provider": "ollama",
  },
  "semantic_tokens": "full",
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "theme": "Glassy Nord Dark",
}
