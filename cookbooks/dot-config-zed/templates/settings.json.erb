{
  // ── Fonts / UI ─────────────────────────────────────────────────────
  "buffer_font_family": "SauceCodePro Nerd Font Mono",
  "buffer_font_size": 15.0,
  "buffer_line_height": "comfortable",
  "text_rendering_mode": "subpixel",
  "ui_font_family": "SauceCodePro Nerd Font Mono",
  "ui_font_size": 16,
  "icon_theme": "Catppuccin Frappé",
  "theme": "Glassy Nord Dark",
  // Zed's integrated terminal does not inherit buffer_font_family; set it
  // explicitly so coralline's powerline glyphs (U+E0B6 caps) render instead
  // of showing as `?`.
  "terminal": {
    "font_family": "SauceCodePro Nerd Font Mono"
  },
  "which_key": {
    "enabled": true
  },

  // ── Vim ────────────────────────────────────────────────────────────
  "vim_mode": true,
  "vim": {
    // Relative in NORMAL, absolute in INSERT. Do NOT also set the static
    // top-level "relative_line_numbers" — it would force relative always
    // and fight this hybrid behavior.
    "toggle_relative_line_numbers": true
  },
  "cursor_blink": false,                          // solid block cursor (vim-friendly); default true

  // ── Save behavior ──────────────────────────────────────────────────
  // Autosave on focus change rather than the old 1s after_delay: with
  // format_on_save enabled, a 1s timer would re-run the formatter while
  // you are mid-edit (cursor jumps). Focus-change saves+formats only when
  // you leave the buffer.
  "autosave": "on_focus_change",
  "format_on_save": "on",                         // default "on"; per-language overridable
  "formatter": "auto",                            // LSP → Prettier fallback; default "auto"
  "remove_trailing_whitespace_on_save": true,     // default true
  "ensure_final_newline_on_save": true,           // default true

  // ── Edit predictions: fully OFF (no provider runs, no code egress) ──
  // The default provider is "zed" (Zeta), which sends editing context to
  // Zed's servers on every keystroke. "provider": "none" is the documented
  // canonical disable; show_edit_predictions:false is a second, independent
  // guarantee that nothing is requested or displayed.
  "edit_predictions": {
    "provider": "none"
  },
  "show_edit_predictions": false,

  // ── Code intelligence display ──────────────────────────────────────
  "code_lens": "on",
  "semantic_tokens": "full",
  "inlay_hints": {
    "enabled": true                               // default false — flip on for typed languages
  },

  // ── Git gutter + inline blame ──────────────────────────────────────
  "git": {
    "git_gutter": "tracked_files",                // default; "hide" disables gutter marks
    "inline_blame": {
      "enabled": true,                            // current-line virtual-text blame
      "delay_ms": 600                             // default 0; 600 avoids flicker while moving
    }
  },

  // ── Line width / wrapping ──────────────────────────────────────────
  "preferred_line_length": 100,                   // default 80
  "wrap_guides": [80, 100],                        // vertical rulers; default []
  "soft_wrap": "preferred_line_length",           // default "none"

  // ── Visual cues / chrome ───────────────────────────────────────────
  "show_whitespaces": "selection",                // none|selection|boundary|trailing|all
  "current_line_highlight": "all",                // none|gutter|line|all
  "scrollbar": {
    "show": "auto"                                // auto|system|always|never
  },
  "minimap": {
    "show": "auto"                                // default "never"; auto = show when useful
  },
  "indent_guides": {
    "enabled": true
  },

  // ── Indentation (per-language overrides below) ─────────────────────
  "tab_size": 2,
  "hard_tabs": false,

  // ── Session / agents ───────────────────────────────────────────────
  "session": {
    "trust_all_worktrees": true
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "default_config_options": {
        "mode": "auto"
      },
      "type": "registry"
    }
  },

  // ── Per-language overrides ─────────────────────────────────────────
  "languages": {
    "Ruby": {
      "language_servers": ["solargraph"]
    },
    "Python": {
      "tab_size": 4,
      // ruff handles formatting; basedpyright (Zed default) handles types.
      "formatter": { "language_server": { "name": "ruff" } },
      "format_on_save": "on"
    },
    "Go": {
      // gofmt uses tabs; match it so manual typing is consistent pre-save.
      "hard_tabs": true,
      "tab_size": 4
    },
    "Markdown": {
      "soft_wrap": "editor_width"
    }
  },

  // ── Language servers ───────────────────────────────────────────────
  "lsp": {
    "solargraph": {
      "binary": {
        "path": "<%= node[:setup][:home] %>/.rbenv/shims/solargraph",
        "arguments": ["stdio"]
      }
    },
    "rust-analyzer": {
      // Use clippy for `check` instead of plain `cargo check`.
      "initialization_options": {
        "check": { "command": "clippy" }
      }
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "inlayHints": {
            "parameterNames": { "enabled": "all", "suppressWhenArgumentMatchesName": false },
            "parameterTypes": { "enabled": true },
            "variableTypes": { "enabled": true }
          }
        }
      }
    },
    "gopls": {
      // Pin the absolute path: GUI-launched Zed has a stripped PATH and
      // Zed's gopls auto-install (which shells out to `go install`) is
      // unreliable there. The cookbook installs gopls to ~/go/bin.
      "binary": {
        "path": "<%= node[:setup][:home] %>/go/bin/gopls",
        "arguments": []
      },
      "initialization_options": {
        "codelenses": {
          "test": true,
          "generate": true,
          "tidy": true,
          "upgrade_dependency": true,
          "vendor": true
        }
      }
    }
  }
}
