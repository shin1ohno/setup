# Auto-generated by elastic-agent cookbook — do not edit (sed-rendered from .tmpl)
#
# Standalone Elastic Agent 9.4.2 config for Linux hosts. Ships system metrics
# + syslog/auth log filestreams to the 3-node ES cluster
# (es-0/1/2.home.local). No Fleet Server; auth via dedicated
# `elastic_agent_writer` user (SSM-managed password injected via systemd
# EnvironmentFile= and resolved at agent startup as ${ELASTIC_AGENT_PASSWORD}).
#
# Placeholders substituted at converge time by sed in default.rb:
#   @@HOSTNAME@@   short hostname (host.name field on every event)
#   @@TAGS@@       comma-separated tag list, JSON-array-formatted
#
# Processors are defined PER-INPUT, never as a top-level global block.
# Elastic Agent 9.4 routes metricbeat inputs (system/metrics, prometheus)
# through an embedded OTel collector whose `processors:` key is a MAP; a
# top-level Beats-style global `processors:` LIST makes the OTel manager
# fail to unmarshal at startup ("'processors' expected type
# map[component.ID]component.Config, got '[]interface {}'") and ALL
# OTel-runtime inputs (system.* metrics + prometheus.collector federation)
# stop shipping fleet-wide — the 2026-05-31 incident. Per Elastic's
# "Elastic Agent as an OpenTelemetry Collector" docs: "Applying a processor
# to all the inputs on a global basis is currently not supported. Processors
# must be defined per-input." Keep these blocks per-input on any future edit.

agent:
  monitoring:
    enabled: true
    use_output: default
    logs: true
    metrics: true

outputs:
  default:
    type: elasticsearch
    # Phase 7-tls: HTTPS to ES cluster. CA cert installed by the
    # elastic-agent cookbook at /etc/elastic-agent/certs/ca.crt
    # (fetched from SSM /monitoring/elastic/ca/cert).
    hosts:
      - https://es-0.home.local:9200
      - https://es-1.home.local:9200
      - https://es-2.home.local:9200
    ssl.certificate_authorities:
      - /etc/elastic-agent/certs/ca.crt
    ssl.verification_mode: full
    username: elastic_agent_writer
    password: ${ELASTIC_AGENT_PASSWORD}

inputs:
  - type: system/metrics
    id: system-metrics
    data_stream:
      namespace: default
    streams:
      - data_stream.dataset: system.cpu
        metricsets: [cpu]
        period: 30s
      - data_stream.dataset: system.memory
        metricsets: [memory]
        period: 30s
      - data_stream.dataset: system.network
        metricsets: [network]
        period: 30s
      - data_stream.dataset: system.filesystem
        metricsets: [filesystem]
        period: 60s
      - data_stream.dataset: system.load
        metricsets: [load]
        period: 30s
      - data_stream.dataset: system.process
        metricsets: [process]
        period: 30s
        processes: ['.*']
        # Limit per-scrape footprint: top 20 by CPU + top 20 by memory.
        # `processes: ['.*']` alone collects every running process per
        # 30s scrape — on small LXCs (samba/pro-router/housekeeping/hydra
        # at 512MB) this triggers OOM-kill of metricbeat. top_n still
        # captures the meaningful processes (heaviest CPU + memory
        # consumers) while bounding scrape memory cost.
        process.include_top_n:
          by_cpu: 20
          by_memory: 20
      - data_stream.dataset: system.uptime
        metricsets: [uptime]
        period: 60s
      # process_summary feeds Kibana Observability "Inventory > Hosts >
      # Processes" view (per-host aggregate counts: total / running /
      # sleeping / stopped / zombie / dead / idle). Distinct dataset
      # from system.process (per-process detail). Both are needed for
      # full Inventory experience.
      - data_stream.dataset: system.process_summary
        metricsets: [process_summary]
        period: 30s
    processors:
      - add_host_metadata: {}
      - add_fields:
          target: host
          fields:
            name: "@@HOSTNAME@@"
      - add_tags:
          tags: @@TAGS@@
          target: tags

  # Journald input — primary log source on Debian/Ubuntu LXCs which
  # use systemd-journal exclusively (no /var/log/syslog by default).
  # Captures both syslog and auth events; per-message routing to
  # logs-system.syslog vs logs-system.auth happens via downstream
  # processors / index template (Elastic-bundled). Without this, LXC
  # hosts ship metrics but zero logs.
  - type: journald
    id: system-journal
    data_stream:
      dataset: system.journal
      namespace: default
    streams:
      - id: system-journal-stream
    processors:
      - add_host_metadata: {}
      - add_fields:
          target: host
          fields:
            name: "@@HOSTNAME@@"
      - add_tags:
          tags: @@TAGS@@
          target: tags

  # Filestream inputs — for hosts that DO write classic /var/log files
  # (bare-metal pro with rsyslog, EC2 AL2023). Harmless no-op on
  # journald-only hosts (filestream sees no files, ships nothing).
  - type: filestream
    id: system-syslog
    data_stream:
      dataset: system.syslog
      namespace: default
    streams:
      - id: system-syslog-stream
        paths:
          - /var/log/syslog
          - /var/log/messages
    processors:
      - add_host_metadata: {}
      - add_fields:
          target: host
          fields:
            name: "@@HOSTNAME@@"
      - add_tags:
          tags: @@TAGS@@
          target: tags

  - type: filestream
    id: system-auth
    data_stream:
      dataset: system.auth
      namespace: default
    streams:
      - id: system-auth-stream
        paths:
          - /var/log/auth.log
          - /var/log/secure
    processors:
      - add_host_metadata: {}
      - add_fields:
          target: host
          fields:
            name: "@@HOSTNAME@@"
      - add_tags:
          tags: @@TAGS@@
          target: tags
@@PROMETHEUS_INPUT@@
@@SYNTHETICS_INPUT@@
@@STACK_MONITORING_INPUT@@
