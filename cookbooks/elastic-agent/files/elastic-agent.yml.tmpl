# Auto-generated by elastic-agent cookbook — do not edit (sed-rendered from .tmpl)
#
# Standalone Elastic Agent 8.16 config. Ships system metrics + syslog/auth log
# filestreams to the 3-node ES cluster (es-0/1/2.home.local). No Fleet Server;
# auth via dedicated `elastic_agent_writer` user (SSM-managed password).
#
# Placeholders substituted at converge time by sed in default.rb:
#   @@HOSTNAME@@   short hostname (host.name field on every event)
#   @@TAGS@@       comma-separated tag list, JSON-array-formatted

agent:
  monitoring:
    enabled: true
    use_output: default
    logs: true
    metrics: true

outputs:
  default:
    type: elasticsearch
    hosts:
      - http://es-0.home.local:9200
      - http://es-1.home.local:9200
      - http://es-2.home.local:9200
    username: elastic_agent_writer
    password: ${ELASTIC_AGENT_PASSWORD}

inputs:
  - type: system/metrics
    id: system-metrics
    data_stream:
      namespace: default
    streams:
      - data_stream.dataset: system.cpu
        metricsets: [cpu]
        period: 30s
      - data_stream.dataset: system.memory
        metricsets: [memory]
        period: 30s
      - data_stream.dataset: system.network
        metricsets: [network]
        period: 30s
      - data_stream.dataset: system.filesystem
        metricsets: [filesystem]
        period: 60s
      - data_stream.dataset: system.load
        metricsets: [load]
        period: 30s
      - data_stream.dataset: system.process
        metricsets: [process]
        period: 30s
        processes: ['.*']

  - type: filestream
    id: system-syslog
    data_stream:
      dataset: system.syslog
      namespace: default
    streams:
      - id: system-syslog-stream
        paths:
          - /var/log/syslog
          - /var/log/messages

  - type: filestream
    id: system-auth
    data_stream:
      dataset: system.auth
      namespace: default
    streams:
      - id: system-auth-stream
        paths:
          - /var/log/auth.log
          - /var/log/secure
@@PROMETHEUS_INPUT@@
processors:
  - add_host_metadata: {}
  - add_fields:
      target: host
      fields:
        name: "@@HOSTNAME@@"
  - add_tags:
      tags: @@TAGS@@
      target: tags
