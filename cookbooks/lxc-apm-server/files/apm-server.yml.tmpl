# Auto-generated by lxc-apm-server cookbook — do not edit
#
# Standalone APM Server config for OTLP ingestion from 5 home-fleet
# services (weave-server, edge-agent, roon-mcp, cognee-auth-proxy,
# ai-memory-auth-proxy). HTTPS on :8200 (LAN-IP-bound per adversarial
# review #10 — Tailscale peers stay out of the OTLP path).
#
# Auth: per-service ES API keys. Each service ships
# `Authorization: ApiKey <encoded>` in its OTLP headers; APM Server
# validates against ES `/_security/api_key`. secret_token and anonymous
# are disabled.
#
# Placeholders substituted at converge time by sed in default.rb:
#   @@LAN_IP@@   the host's LAN IP (192.168.1.81 for apm-server)

apm-server:
  host: "@@LAN_IP@@:8200"
  ssl:
    enabled: true
    certificate: /etc/apm-server/certs/server.crt
    key: /etc/apm-server/certs/server.key
  auth:
    api_key:
      enabled: true
      # Per-service API keys are issued by bin/issue-apm-api-keys.sh and
      # stored in SSM /monitoring/apm/api-keys/<svc>. Limits left at
      # defaults (no fleet-side rate cap; we trust the LAN-bind + IAM
      # KMS scope to keep API key distribution to the intended 5 SVCs).
      limit: 100
    anonymous:
      enabled: false
    secret_token: ""
  rum:
    enabled: false
  # Idle connection timeout: 30s matches the OTel SDK default batch
  # exporter flush interval. Longer would leak ESTABLISHED conns on the
  # apm-server side without traffic (cf. cognee/auth-proxy SSE leak class).
  idle_timeout: 30s
  # Read timeout: 30s caps slow uploads. OTLP batches are small (<1 MB
  # typical), so 30s is generous. shutdown_timeout left at default (5s).
  read_timeout: 30s

# Output to the 3-node ES cluster (TLS, apm_server_writer user). Uses
# the in-process Elasticsearch output — no Kafka / Logstash / Filebeat
# in the path. APM Server writes traces-apm-* / logs-apm-* /
# metrics-apm-* data streams; the index templates ship with the
# Elastic APM integration package and auto-install on first write
# (the `manage_index_templates` cluster privilege on apm_server_writer
# allows this).
output.elasticsearch:
  hosts:
    - https://es-0.home.local:9200
    - https://es-1.home.local:9200
    - https://es-2.home.local:9200
  ssl:
    certificate_authorities:
      - /etc/apm-server/certs/ca.crt
    verification_mode: full
  protocol: https
  username: apm_server_writer
  password: "${APM_SERVER_PASSWORD}"
  # Bulk + worker tuning — defaults are conservative for a single-VM
  # home setup; bump worker count to keep up with 5 services at
  # ~10-100 req/s aggregate without queueing pressure.
  worker: 2
  bulk_max_size: 512

# Logging — INFO level, stderr (journald captures via DEB systemd unit).
# Plain JSON output for easy parsing in Discover later if needed.
logging:
  level: info
  to_stderr: true
  json: true
  metrics:
    enabled: false  # internal metrics are forwarded to ES too noisy; keep off

# Monitoring: disabled to avoid recursive trace ingest. Re-enable via
# Stack Monitoring (Kibana → Stack Monitoring) if we ever want
# apm-server-self metrics.
monitoring:
  enabled: false
