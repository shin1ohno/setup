# Rendered at deploy time by lxc-elasticsearch/default.rb — substitutes
# @@NODE_NAME@@ and @@TRANSPORT_HOST@@ from the per-LXC node attributes.
# Phase 3b ships transport-TLS only; xpack.security.http.ssl.enabled is
# left disabled (set to true in Phase 7-tls).
cluster.name: es-home-monitor
node.name: @@NODE_NAME@@
node.roles: [master, data, ingest]

# Native systemd install — ES binds directly to the LXC's interface IP.
# No docker-bridge netns split required (the bind/publish workaround was
# a docker-ism). network.host covers both HTTP (9200) and transport (9300).
network.host: @@TRANSPORT_HOST@@
http.port: 9200
transport.port: 9300

# Static cluster discovery — three combined-role nodes.
discovery.seed_hosts:
  - 192.168.1.77:9300   # es-0 (CT 112)
  - 192.168.1.78:9300   # es-1 (CT 113)
  - 192.168.1.79:9300   # es-2 (CT 114)
cluster.initial_master_nodes:
  - es-0
  - es-1
  - es-2

# Memory locking — requires LXC `lxc.prlimit.memlock unlimited` (Phase 3a
# manual op) + LimitMEMLOCK=infinity in the systemd override (Phase 3b
# native). The DEB unit defaults LimitMEMLOCK to infinity, but the
# override re-states it for cookbook-source-of-truth clarity.
bootstrap.memory_lock: true

# Synthetic _source mode is configured per-index via component templates
# (see files/component-templates/logs-rtx-mappings.json).

# === Security ===
xpack.security.enabled: true
xpack.security.autoconfiguration.enabled: false

# Transport TLS — node-to-node communication. Cert + key are PEM files
# fetched from SSM and installed at /data/elasticsearch/certs/ by the
# cookbook. Absolute paths because the native ES install reads them at
# bootstrap; relative paths (resolved against ES_PATH_CONF=/etc/elasticsearch
# for native) would not point at the bind-mount destination.
xpack.security.transport.ssl.enabled: true
xpack.security.transport.ssl.verification_mode: certificate
xpack.security.transport.ssl.client_authentication: required
xpack.security.transport.ssl.key: /data/elasticsearch/certs/@@NODE_NAME@@.key
xpack.security.transport.ssl.certificate: /data/elasticsearch/certs/@@NODE_NAME@@.crt
xpack.security.transport.ssl.certificate_authorities:
  - /data/elasticsearch/certs/ca.crt

# HTTP TLS — disabled in Phase 3b. Switch to true in Phase 7-tls and
# point at the same node cert.
xpack.security.http.ssl.enabled: false

# Native install: ES reads /etc/elasticsearch/elasticsearch.yml. The
# data, logs, and certs directories live under /data/elasticsearch/ via
# the path.* directives below (DEB default would be /var/lib/elasticsearch
# and /var/log/elasticsearch).
path.data: /data/elasticsearch/data
path.logs: /data/elasticsearch/logs
