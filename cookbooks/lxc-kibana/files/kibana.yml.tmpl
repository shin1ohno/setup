# Phase 3b: ES is HTTP plain (transport-TLS only). Kibana therefore
# connects via http://. Phase 7-tls switches to https:// + CA cert
# verification.
server.host: 0.0.0.0
server.port: 5601
server.publicBaseUrl: "https://monitoring.ohno.be"

# SameSite=None required because the EC2 nginx proxy origin
# (monitoring.ohno.be) differs from Kibana's bind host (kibana.home.local);
# Secure cookies are auto-set by Kibana when X-Forwarded-Proto=https.
# Kibana 8.x key is `xpack.security.sameSiteCookies` — earlier
# `xpack.security.session.sameSiteAttribute` failed validation with
# "definition for this key is missing" (FATAL on startup).
xpack.security.sameSiteCookies: "None"

# `SameSite: None` cookies require `Secure` per RFC 6265bis. Without
# this Kibana logs ERROR "SameSite: None requires Secure connection"
# on every request and returns 500 to the browser. server.ssl is OFF
# (TLS terminated at the EC2 nginx proxy), so we must explicitly tell
# Kibana to issue Secure cookies regardless of its own bind protocol.
xpack.security.secureCookies: true

# Native install: data dir override (DEB default is /var/lib/kibana).
# /data/kibana is on rpool inside the LXC (50 GB, no bind-mount).
path.data: /data/kibana/data

# Phase 7-tls: HTTPS to ES cluster. CA cert installed at
# /etc/kibana/certs/ca.crt by the lxc-kibana cookbook (fetched from
# SSM /monitoring/elastic/ca/cert, mode 0640 root:kibana).
elasticsearch.hosts:
  - https://es-0.home.local:9200
  - https://es-1.home.local:9200
  - https://es-2.home.local:9200
elasticsearch.ssl.certificateAuthorities:
  - /etc/kibana/certs/ca.crt
elasticsearch.ssl.verificationMode: full

elasticsearch.username: kibana_system
elasticsearch.password: "${KIBANA_PASSWORD}"

# Allow up to 90s for ES quorum to form during the rolling restart of
# the 3-node cluster. Default 30s is too tight when es-0 boots first
# and waits for es-1/es-2 to register.
elasticsearch.requestTimeout: 90000

# Encryption keys (32-char hex from SSM, set in /etc/kibana/kibana-secrets.env
# via systemd EnvironmentFile=). Required to survive Kibana restarts
# without re-encrypting saved objects on every boot. Kibana 8.x supports
# ${VAR} substitution natively from process environment.
xpack.encryptedSavedObjects.encryptionKey: "${KIBANA_ENC_SO_KEY}"
xpack.reporting.encryptionKey:             "${KIBANA_ENC_REPORT_KEY}"
xpack.security.encryptionKey:              "${KIBANA_ENC_SEC_KEY}"

# Phase 7-tls anchor: when ES HTTP TLS is enabled, replace
# elasticsearch.hosts with https:// URLs and uncomment:
#
# elasticsearch.ssl.certificateAuthorities:
#   - /etc/kibana/certs/ca.crt
# elasticsearch.ssl.verificationMode: certificate

# Logging
logging.appenders.default:
  type: console
  layout:
    type: pattern
    pattern: "[%date][%level][%logger] %message"
logging.root.level: info

# Telemetry off — LAN-only personal deployment.
telemetry.enabled: false

# Stack Monitoring: single self-monitoring cluster, no dedicated monitoring
# cluster. The default `monitoring.ui.ccs.enabled: true` makes the Stack
# Monitoring app issue Cross Cluster Search queries (cluster:.monitoring-*),
# which fail because the ES nodes have roles [master,data,ingest] only — no
# `remote_cluster_client` — surfacing as a misleading "Access Denied / not
# authorized to access Monitoring" page even for the elastic superuser.
# Disabling CCS makes the app query the LOCAL cluster, where the
# elastic-agent-collected metrics-{elasticsearch,kibana}.stack_monitoring.*
# data streams live.
monitoring.ui.ccs.enabled: false

# Disable Kibana's legacy self-monitoring collection. The standalone
# elastic-agent on CT 111 (kibana/metrics input) now collects Kibana stack
# monitoring data into metrics-kibana.stack_monitoring.*. Left at the default
# `true`, Kibana keeps self-collecting via the legacy path, which makes the
# Stack Monitoring UI's setup-mode detector report "internal collection
# detected — Metricbeat monitoring is not enabled" and show a migration
# prompt (the detector is hard-wired to legacy .monitoring-* / -mb- index
# names and cannot recognize agent data streams — elastic/kibana#172435).
# Turning self-collection off removes the migration prompt; the agent is
# the sole collector so no Kibana monitoring data is lost. ES-side
# xpack.monitoring.collection.enabled is already false (default).
monitoring.kibana.collection.enabled: false
