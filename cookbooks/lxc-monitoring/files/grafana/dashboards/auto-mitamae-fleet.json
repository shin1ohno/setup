{
  "annotations": { "list": [] },
  "description": "Auto-mitamae fleet dashboard. Top row classifies hosts into 4 severity tiers (succeeded / hard failing / transient / stale) plus drift-checker status + main HEAD. Bottom half is a per-host card grid. Severity: hard fail = mitamae_fail / ssh_unreachable / git_fail / git_fetch_fail / invalid_command (operator action). Transient = sha_mismatch / lock_held (self-heals next cycle). Stale = last apply timestamp older than 30 min (~2× cycle, orchestrator-side issue).",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Hosts with status=success and timestamp within last 30 min (~2× cycle).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green",  "value": 2 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "count((auto_mitamae_last_apply_status{result=\"success\"} == 1) and on(host) (time() - auto_mitamae_last_apply_timestamp_seconds <= 1800))",
          "instant": true, "legendFormat": "succeeded", "range": false, "refId": "A"
        }
      ],
      "title": "Hosts: last apply succeeded",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Hard-failing hosts (operator action required): mitamae_fail / ssh_unreachable / git_fail / git_fetch_fail / invalid_command, AND timestamp within last 30 min. Transient (sha_mismatch / lock_held) and stale hosts are surfaced in adjacent panels.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "count((auto_mitamae_last_apply_status{result=~\"mitamae_fail|ssh_unreachable|git_fail|git_fetch_fail|invalid_command\"} == 1) and on(host) (time() - auto_mitamae_last_apply_timestamp_seconds <= 1800)) or vector(0)",
          "instant": true, "legendFormat": "hard failing", "range": false, "refId": "A"
        }
      ],
      "title": "Hosts: hard failing",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "drift-checker's last poll outcome. Red = api_failure (rate-limit / 5xx). Yellow = parse_failure. Green = ok.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "ok":             { "color": "green",  "index": 0, "text": "OK" } },             "type": "value" },
            { "options": { "api_failure":    { "color": "red",    "index": 1, "text": "API FAILURE" } },    "type": "value" },
            { "options": { "parse_failure":  { "color": "yellow", "index": 2, "text": "PARSE FAILURE" } },  "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "string"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^result$/", "values": true },
        "textMode": "value"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "setup_main_head_check_status == 1",
          "format": "table",
          "instant": true, "legendFormat": "__auto", "range": false, "refId": "A"
        }
      ],
      "title": "GitHub API status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "main HEAD commit observed by drift-checker.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "string"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^commit$/", "values": true },
        "textMode": "value"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "setup_main_head_commit_info",
          "format": "table",
          "instant": true, "legendFormat": "__auto", "range": false, "refId": "A"
        }
      ],
      "title": "setup main HEAD",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Transient hosts (self-heals next cycle, watch only): sha_mismatch (host's git fetch lagged) / lock_held (concurrent apply). Excludes stale entries.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "id": 6,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "count((auto_mitamae_last_apply_status{result=~\"sha_mismatch|lock_held\"} == 1) and on(host) (time() - auto_mitamae_last_apply_timestamp_seconds <= 1800)) or vector(0)",
          "instant": true, "legendFormat": "transient", "range": false, "refId": "A"
        }
      ],
      "title": "Hosts: transient",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Stale hosts: orchestrator has not refreshed this host's metrics within the last 30 min (~2× cycle). Indicates an orchestrator-side issue (cron paused, lock stuck, host omitted from hosts.json).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "purple", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "id": 7,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "count(time() - auto_mitamae_last_apply_timestamp_seconds > 1800) or vector(0)",
          "instant": true, "legendFormat": "stale", "range": false, "refId": "A"
        }
      ],
      "title": "Hosts: stale",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "One card per fleet host. Background colors by result severity (hard fail=red: mitamae_fail / ssh_unreachable / git_fail / git_fetch_fail / invalid_command. transient=yellow: sha_mismatch / lock_held. success=green). Within each card: result text, time since last apply, drift commits behind main, and pinned indicator (✓ if applied SHA == orchestrator's expected SHA, ✗ otherwise).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "mappings", "value": [
                {
                  "type": "value",
                  "options": {
                    "success":         { "color": "green",  "text": "✓ OK",        "index": 0 },
                    "mitamae_fail":    { "color": "red",    "text": "❌ FAIL",     "index": 1 },
                    "sha_mismatch":    { "color": "yellow", "text": "⚠ MISMATCH",  "index": 2 },
                    "ssh_unreachable": { "color": "red",    "text": "⊘ UNREACH",   "index": 3 },
                    "git_fail":        { "color": "red",    "text": "⊘ GIT FAIL",  "index": 4 },
                    "git_fetch_fail":  { "color": "red",    "text": "⊘ GIT FETCH", "index": 5 },
                    "lock_held":       { "color": "yellow", "text": "⚠ LOCKED",    "index": 6 },
                    "invalid_command": { "color": "red",    "text": "⚠ PROTOCOL",  "index": 7 }
                  }
                }
              ]}
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "Applied" },
              { "id": "unit", "value": "s" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green",  "value": null },
                { "color": "yellow", "value": 7200 },
                { "color": "red",    "value": 86400 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "C" },
            "properties": [
              { "id": "displayName", "value": "Drift" },
              { "id": "unit", "value": "none" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green",  "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red",    "value": 5 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "D" },
            "properties": [
              { "id": "displayName", "value": "Pinned" },
              { "id": "mappings", "value": [
                {
                  "type": "value",
                  "options": {
                    "1": { "color": "green", "text": "✓", "index": 0 },
                    "0": { "color": "red",   "text": "✗", "index": 1 }
                  }
                }
              ]}
            ]
          }
        ]
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 5 },
      "id": 5,
      "maxPerRow": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.6.14",
      "repeat": "host",
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "auto_mitamae_last_apply_status{host=\"$host\"}",
          "format": "table",
          "instant": true, "legendFormat": "__auto", "range": false, "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "time() - auto_mitamae_last_apply_timestamp_seconds{host=\"$host\"}",
          "instant": true, "legendFormat": "__auto", "range": false, "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "auto_mitamae_last_apply_drift_commits{host=\"$host\"}",
          "instant": true, "legendFormat": "__auto", "range": false, "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "clamp_max(sum by (host) (auto_mitamae_last_apply_sha_info{host=\"$host\"} * on(sha) group_left() label_replace(auto_mitamae_orchestrator_expected_sha_info, \"sha\", \"$1\", \"commit\", \"(.+)\")), 1) or on() (sum(auto_mitamae_last_apply_sha_info{host=\"$host\"}) * 0)",
          "instant": true, "legendFormat": "__auto", "range": false, "refId": "D"
        }
      ],
      "title": "${host}",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["fleet", "auto-mitamae"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(auto_mitamae_last_apply_status, host)",
        "hide": 2,
        "includeAll": true,
        "label": "Host",
        "multi": true,
        "name": "host",
        "options": [],
        "query": {
          "qryType": 1,
          "refId": "PrometheusVariableQueryEditor-VariableQuery",
          "query": "label_values(auto_mitamae_last_apply_status, host)"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Auto-mitamae Fleet",
  "uid": "auto-mitamae-fleet",
  "version": 4,
  "weekStart": ""
}
