{
  "annotations": {
    "list": []
  },
  "description": "YAMAHA RTX router syslog visualization (Phase B). Receives forwarded syslog over UDP 1514 via Promtail, stored in Loki, parsed for filter PASS/REJECT, IKE/IPsec session events, DHCP lease events, and GeoIP-enriched source IPs. Sibling of the RTX Routers (SNMP metrics) dashboard.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Total log lines received in the last hour for the selected router(s).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({router=~\"$router\"}[1h]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "ログ件数 (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "REJECT-classified events in the last hour. Sustained values >100/h on the WAN-facing router (hnd) usually indicate active scanning from a new source range — drill into the GeoIP map and top-source table to investigate.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({router=~\"$router\", action=\"REJECT\"}[1h]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "REJECT 件数 (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Distinct source IP addresses observed in REJECT events over the last hour.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "count(count by(src) (count_over_time({router=~\"$router\", action=\"REJECT\"}[1h])))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "ユニーク送信元 IP (REJECT, 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Per-minute log volume stacked by syslog severity. Sudden spikes in info/notice indicate either link state transitions or a misconfiguration loop; debug volume is normally near zero unless RTX debug log is on.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "",
            "axisPlacement": "auto", "barAlignment": 0,
            "drawStyle": "line", "fillOpacity": 30, "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 1,
            "pointSize": 5, "scaleDistribution": { "type": "linear" },
            "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by(severity) (count_over_time({router=~\"$router\"}[1m]))",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "title": "ログ流量 (severity 別、1m bucket、stacked)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "送信元の世界マップ。Vector の enrichment_tables が dbip-city-lite で経緯度を埋め、structured metadata として保存している。bubble size は count に比例、PASS/REJECT は Filter action 変数で切替 (デフォルト All)。LAN 内 IP は GeoIP マッピングが無いので地図に出ない。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 12 },
      "id": 5,
      "options": {
        "basemap": { "config": {}, "name": "Layer 0", "type": "default" },
        "controls": {
          "mouseWheelZoom": true, "showAttribution": true,
          "showDebug": false, "showMeasure": false, "showScale": false, "showZoom": true
        },
        "layers": [
          {
            "config": {
              "showLegend": true,
              "style": {
                "color": { "fixed": "red" },
                "opacity": 0.6,
                "rotation": { "fixed": 0, "max": 360, "min": -360, "mode": "mod" },
                "size": { "field": "Value", "fixed": 5, "max": 24, "min": 4 },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "textConfig": { "fontSize": 12, "offsetX": 0, "offsetY": 0, "textAlign": "center", "textBaseline": "middle" }
              }
            },
            "location": { "latitude": "geoip_latitude", "longitude": "geoip_longitude", "mode": "coords" },
            "name": "Sources",
            "tooltip": true, "type": "markers"
          }
        ],
        "tooltip": { "mode": "details" },
        "view": { "id": "zero", "lat": 0, "lon": 0, "zoom": 2 }
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "topk(50, sum by(src, geoip_country_code, geoip_latitude, geoip_longitude, action) (count_over_time({router=~\"$router\", action=~\"$action\"}[$__range])))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "送信元マップ",
      "type": "geomap"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "件数を国別 × Filter action (PASS/REJECT) で top 15 表示。GeoIP マッピングが無い (LAN 内 / 不明) ものは empty country_code として独立 bar になる。Filter action 変数で全体・PASS・REJECT を切替可能。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 12 },
      "id": 6,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10, "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true, "valueMode": "color"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "topk(15, sum by(geoip_country_code, action) (count_over_time({router=~\"$router\", action=~\"$action\"}[$__range])))",
          "legendFormat": "{{geoip_country_code}} ({{action}})",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "件数 (国別 Top 15、action 別)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Top 20 送信元 IP × Filter action (PASS/REJECT)。同じ src が PASS と REJECT 両方に登場する場合は別行として表示される。詳細を見たい IP があれば Live logs パネルでそのまま検索できる。Filter action 変数で全体・PASS・REJECT を切替可能。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "topk(20, sum by(src, action) (count_over_time({router=~\"$router\", action=~\"$action\"}[$__range])))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top 20 送信元 IP (action 別)",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Top 20 宛先 port × Filter action (PASS/REJECT)。REJECT 側で 22, 23, 3389, 445 etc. が継続的に上位なら一般的な scan パターン。PASS 側は宛先サービスごとの正常通信の port 分布。新しい REJECT port が急浮上したら新規攻撃 vector の可能性。Filter action 変数で全体・PASS・REJECT を切替可能。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "topk(20, sum by(dst_port, action) (count_over_time({router=~\"$router\", action=~\"$action\"}[$__range])))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top 20 宛先 port (action 別)",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "ライブログストリーム。$router / $severity / $action の組み合わせで絞り込める。tail mode で右上の live ボタンを押すと自動更新。",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 32 },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{router=~\"$router\", severity=~\"$severity\", action=~\"$action\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "ライブログ",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "[IKE]/[IKE2] phase の VPN session イベント。`initiate IPsec phase to <peer>` / `SA established` / `SA deleted` のシーケンスで、各 peer の接続生存を追える。",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 44 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{router=~\"$router\"} |~ \"\\\\[IKE2?\\\\]\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "VPN (IKE / IPsec) イベント",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "[DHCPD] イベント。Extends / Assigns / Releases で lease ライフサイクルを観測。lease_ip と mac は structured metadata。新規 mac が Assigns で出現したら新デバイス、急に Releases が増えたら子供端末がスリープに入ったとか LAN 切替えの可能性。",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 50 },
      "id": 11,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{router=\"hnd\"} |~ \"\\\\[DHCPD\\\\]\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "DHCP lease イベント (hnd)",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["network", "rtx", "logs", "loki"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "hide": 0,
        "includeAll": true,
        "label": "Router",
        "multi": true,
        "name": "router",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "hnd", "value": "hnd" },
          { "selected": false, "text": "itm", "value": "itm" }
        ],
        "query": "hnd, itm",
        "queryValue": "",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "label": "Severity",
        "multi": true,
        "name": "severity",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "notice", "value": "notice" },
          { "selected": false, "text": "info", "value": "info" },
          { "selected": false, "text": "debug", "value": "debug" },
          { "selected": false, "text": "err", "value": "err" }
        ],
        "query": "notice, info, debug, err",
        "queryValue": "",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "label": "Filter action",
        "multi": true,
        "name": "action",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "PASS", "value": "PASS" },
          { "selected": false, "text": "REJECT", "value": "REJECT" }
        ],
        "query": "PASS, REJECT",
        "queryValue": "",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": "Loki", "value": "loki" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "RTX Logs",
  "uid": "rtx-logs",
  "version": 1,
  "weekStart": ""
}
