    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "LAN1 (RTX1210 hnd: trunk to L2 switch / LAN1 port) — bps in/out.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "",
            "axisPlacement": "auto", "barAlignment": 0,
            "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear", "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(ifHCInOctets{job=\"snmp-rtx\", router=~\"$router\", ifName=~\"lan1.*\"}[5m]) * 8",
          "legendFormat": "{{router}}/{{ifName}} in", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(ifHCOutOctets{job=\"snmp-rtx\", router=~\"$router\", ifName=~\"lan1.*\"}[5m]) * 8",
          "legendFormat": "{{router}}/{{ifName}} out", "refId": "B"
        }
      ],
      "title": "LAN1 bandwidth",
      "type": "timeseries"
    },
    {
