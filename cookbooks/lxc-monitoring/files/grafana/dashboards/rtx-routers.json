      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "yrfRevision_info{job=\"snmp-rtx\", router=~\"$router\"}",
          "format": "table", "instant": true, "legendFormat": "{{router}}", "range": false, "refId": "A"
        }
      ],
      "title": "Firmware",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
