{
  "annotations": {
    "list": [
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "expr": "up{job=\"snmp-rtx\", router=~\"$router\"} == 0",
        "iconColor": "red",
        "name": "Scrape failure",
        "titleFormat": "snmp-rtx scrape failed",
        "tagKeys": "router"
      }
    ]
  },
  "description": "YAMAHA RTX router metrics via snmp-exporter. Covers hnd (RTX1210, .253) and itm (RTX830, .254) — uptime, firmware, CPU, memory, temperature, interface bandwidth/errors, and the L2TPv3 backhaul tunnel state. Phase A — extend with Loki/Promtail syslog visualization in Phase B.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "System uptime as reported by SNMPv2-MIB sysUpTime (per router).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.6.14",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sysUpTime{job=\"snmp-rtx\", router=~\"$router\"} / 100",
          "instant": true, "legendFormat": "{{router}}", "range": false, "refId": "A"
        }
      ],
      "title": "Uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Firmware revision (yrfRevision) per router — appears as DisplayString label on the metric.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "yrfRevision", "values": false },
        "textMode": "value_and_name"
