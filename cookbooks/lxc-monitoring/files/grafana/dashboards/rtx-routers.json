    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Per-interface state table: admin/oper status, link speed, current bandwidth utilization. Useful for spotting flapping interfaces or wrong-speed links.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [ { "id": "displayName", "value": "Admin" } ] },
          { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [ { "id": "displayName", "value": "Oper" } ] },
          { "matcher": { "id": "byName", "options": "Value #C" }, "properties": [ { "id": "displayName", "value": "Speed (bps)" }, { "id": "unit", "value": "bps" } ] },
          { "matcher": { "id": "byName", "options": "Value #D" }, "properties": [ { "id": "displayName", "value": "In (bps)" }, { "id": "unit", "value": "bps" } ] },
          { "matcher": { "id": "byName", "options": "Value #E" }, "properties": [ { "id": "displayName", "value": "Out (bps)" }, { "id": "unit", "value": "bps" } ] }
        ]
