        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "ifOperStatus{job=\"snmp-rtx\", router=~\"$router\"}",
          "format": "table", "instant": true, "legendFormat": "__auto", "range": false, "refId": "B"
