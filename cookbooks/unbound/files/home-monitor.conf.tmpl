# /etc/unbound/unbound.conf.d/home-monitor.conf
# Managed by mitamae (cookbooks/unbound). DO NOT EDIT BY HAND.
# Rendered from this template by cookbooks/unbound/files/generate-home-local.sh
# (the dedicated marker line further below is replaced with home.local local-data).
#
# LAN DNS resolver for 192.168.1.0/24, replacing the RTX1210 forwarder which
# does not serve TCP/53 (RFC 7766 TCP-fallback on truncated responses fails
# there, breaking Linux name resolution on large/DNSSEC/long-TXT answers).
#   home.local              -> served LOCALLY from local-data (see marker below);
#                              unknown names fall through to VPC Route53 (10.33.128.2)
#   1.168.192.in-addr.arpa  -> VPC Route53 resolver (10.33.128.2)
#   everything else         -> Cloudflare DoT (1.1.1.1@853 / 1.0.0.1@853)

server:
    interface: 0.0.0.0@53
    port: 53
    do-ip4: yes
    # IPv4-only resolver: the LAN has no IPv6 RA. AAAA records are still
    # resolved and returned over IPv4 transport, so client IPv6 connectivity is
    # unaffected — only this resolver's own listen/transport is IPv4.
    do-ip6: no
    do-udp: yes
    do-tcp: yes

    # NOTE: deliberately NO `interface-automatic` here. It was tried 2026-05-31
    # to fix the "active but zero replies on eth0" wedge and did NOT help — the
    # wedge recurred immediately after enabling it. The wedge is an intermittent
    # unbound startup condition, independent of this option (it also occurred
    # without it), and `interface-automatic` is flagged experimental + interacts
    # with so-reuseport. The off-box cookbooks/unbound-watchdog auto-restarts
    # unbound when the wedge occurs — that is the actual fix.

    # Access control: LAN + loopback only. Never an open resolver.
    # ::1/128 is listed for forward-compat if do-ip6 is ever flipped to yes.
    access-control: 0.0.0.0/0 refuse
    access-control: 127.0.0.0/8 allow
    access-control: ::1/128 allow
    access-control: 192.168.1.0/24 allow

    # home.local / reverse are UNSIGNED internal zones reached via a forwarder;
    # tell the validator not to require a DNSSEC chain of trust for them.
    domain-insecure: "home.local."
    domain-insecure: "1.168.192.in-addr.arpa."

    # --- home.local served LOCALLY (VPC-independent), rendered from SSM ---
    # ALL home.local A records (home-monitor local.private_dns_forward, published
    # to SSM /host-registry/home-local-records) are served as local-data here, so
    # home.local resolution does NOT depend on the VPC Route53 forward path
    # (10.33.128.2 over the Tailscale subnet route). That forward path is
    # wedge-prone: a transient VPC outage pushes the forwarder RTO to the 120000ms
    # cap and unbound SERVFAILs home.local until restarted (observed 2026-05-31 /
    # 2026-06-02). Serving locally mirrors what the RTX rtx_dns_server "hosts"
    # block did (now retired) and also load-sheds the ELK fleet's burst lookups
    # off the ~90ms forward path. The block below is rendered at deploy time by
    # cookbooks/unbound/files/generate-home-local.sh from the SSM map; names NOT
    # in the registry still fall through to the forward-zone (Route53). If the SSM
    # fetch fails, the marker renders empty and home.local degrades to forward-only.
    # @@HOME_LOCAL_LOCAL_DATA@@

    # Search-domain doubling guard. Clients with a high ndots query the doubled
    # name <name>.home.local.home.local FIRST; those are always bogus but were
    # forwarded to 10.33.128.2 and SERVFAIL'd — the bulk of the original storm.
    # Answer NXDOMAIN locally so the client instantly falls through to the real
    # <name>.home.local.
    local-zone: "home.local.home.local." always_nxdomain

    # Watchdog canary. The off-box unbound-watchdog (PVE host timer,
    # cookbooks/unbound-watchdog) resolves this name via the LAN IP every 60s.
    # A timeout => unbound wedged/down; an empty/wrong answer => unbound is
    # running a stale config that predates this canary (deployed-but-not-reloaded,
    # the 2026-05-31 root cause). Either restarts unbound. TTL 0 so nothing caches
    # a stale positive; 192.0.2.1 is an RFC 5737 TEST-NET sentinel, never routed.
    local-zone: "unbound-watchdog.health." static
    local-data: "unbound-watchdog.health. 0 IN A 192.0.2.1"

    # DoT upstream certificate validation
    tls-cert-bundle: "/etc/ssl/certs/ca-certificates.crt"

    # Hardening / hygiene
    hide-identity: yes
    hide-version: yes
    harden-glue: yes
    harden-dnssec-stripped: yes
    qname-minimisation: yes
    prefetch: yes
    edns-buffer-size: 1232
    # CT118 has 2 cores. A single thread serialises the ~90ms home.local forwards
    # (10.33.128.2 over the Tailscale subnet route); under fleet query bursts the
    # requestlist backed up and LAN clients hit intermittent multi-second DNS
    # timeouts (2026-05-31). Two threads double forward concurrency so bursts are
    # absorbed instead of queued. Keep <= nproc to avoid oversubscription.
    num-threads: 2
    verbosity: 1
    use-syslog: yes

# Internal zones -> VPC Route53 Resolver (plain DNS over the LAN static route).
# home.local is also served from local-data above; this forward-zone is the
# fallback for any home.local name not in the SSM registry, plus reverse PTR.
forward-zone:
    name: "home.local."
    forward-addr: 10.33.128.2

forward-zone:
    name: "1.168.192.in-addr.arpa."
    forward-addr: 10.33.128.2

# Public -> DNS-over-TLS, two independent operators for availability.
# Cloudflare (1.1.1.1 / 1.0.0.1) + Quad9 (9.9.9.9 / 149.112.112.112). unbound
# prefers the fastest and fails over between them, so a single-operator outage
# (port 853 blocked, provider incident) degrades instead of hard-failing.
# DoT-only by design: there is intentionally NO plaintext fallback. Do NOT add
# forward-first: yes — with DoT-only forward-addr it would attempt a
# privacy-defeating plaintext retry with no plaintext target. Last-resort manual
# fallback if ALL DoT is unreachable: the RTX1210 stays up — temporarily repoint
# LAN DHCP DNS (or /etc/resolv.conf) to 1.1.1.1 until DoT recovers.
forward-zone:
    name: "."
    forward-tls-upstream: yes
    forward-addr: 1.1.1.1@853#cloudflare-dns.com
    forward-addr: 1.0.0.1@853#cloudflare-dns.com
    forward-addr: 9.9.9.9@853#dns.quad9.net
    forward-addr: 149.112.112.112@853#dns.quad9.net
