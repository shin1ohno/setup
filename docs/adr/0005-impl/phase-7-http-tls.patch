# Phase 7-tls patch — apply with `git apply` after Phase 3b + 6 merged.
#
# Pre-conditions:
#   - cookbooks/lxc-elasticsearch/ exists (Phase 3b)
#   - cookbooks/lxc-kibana/ exists (Phase 3b)
#   - Cluster is healthy on plain HTTP + basic auth
#   - SAN audit passes: `openssl x509 -in es-N.crt -text -noout | grep -A1 SAN`
#     contains DNS:es-{0,1,2}.home.local + DNS:localhost + IP:127.0.0.1
#
# These hunks assume Phase 3b's elasticsearch.yml.tmpl has the existing transport
# TLS block at the listed line numbers. If Phase 3b shipped a different layout,
# treat the diff as semantic spec, not a verbatim patch — the change is:
#   - flip `xpack.security.http.ssl.enabled` from false → true
#   - add 3 path keys mirroring the transport.ssl.* keys
#   - flip kibana's `elasticsearch.hosts` to https + add ssl block
#
diff --git a/cookbooks/lxc-elasticsearch/files/elasticsearch.yml.tmpl b/cookbooks/lxc-elasticsearch/files/elasticsearch.yml.tmpl
--- a/cookbooks/lxc-elasticsearch/files/elasticsearch.yml.tmpl
+++ b/cookbooks/lxc-elasticsearch/files/elasticsearch.yml.tmpl
@@ -- ES Security: HTTP layer --
-# Phase 3b: HTTP layer plain + basic auth (deferred until Phase 7-tls)
-xpack.security.http.ssl.enabled: false
+# Phase 7-tls: HTTP layer TLS — re-uses the transport-layer node cert.
+# CA + node cert + key were installed by Phase 3b at /usr/share/elasticsearch/config/certs/.
+# SAN must include DNS:es-{0,1,2}.home.local + DNS:localhost + IP:127.0.0.1
+# (audit before apply: openssl x509 -in <cert> -text -noout | grep -A1 SAN).
+xpack.security.http.ssl.enabled: true
+xpack.security.http.ssl.key: /usr/share/elasticsearch/config/certs/${NODE_NAME}.key
+xpack.security.http.ssl.certificate: /usr/share/elasticsearch/config/certs/${NODE_NAME}.crt
+xpack.security.http.ssl.certificate_authorities: /usr/share/elasticsearch/config/certs/ca.crt

diff --git a/cookbooks/lxc-kibana/files/kibana.yml.tmpl b/cookbooks/lxc-kibana/files/kibana.yml.tmpl
--- a/cookbooks/lxc-kibana/files/kibana.yml.tmpl
+++ b/cookbooks/lxc-kibana/files/kibana.yml.tmpl
@@ -- Elasticsearch connection --
-# Phase 3b: plain HTTP + basic auth
-elasticsearch.hosts: ['http://es-0.home.local:9200', 'http://es-1.home.local:9200', 'http://es-2.home.local:9200']
+# Phase 7-tls: HTTPS to ES cluster.
+# CA cert installed by Phase 3b at /data/kibana/certs/ca.crt (chmod 0644, ownership matches kibana container UID).
+# verificationMode 'full' enforces hostname match against SAN — SAN audit above is the gate.
+elasticsearch.hosts: ['https://es-0.home.local:9200', 'https://es-1.home.local:9200', 'https://es-2.home.local:9200']
+elasticsearch.ssl.certificateAuthorities: ['/usr/share/kibana/config/certs/ca.crt']
+elasticsearch.ssl.verificationMode: full

# --- Notes for the agent applying this patch ---
#
# 1. cookbooks/lxc-elasticsearch/default.rb requires NO change. The cert
#    fetch + install resources from Phase 3b already place ca.crt + node cert
#    + key under /usr/share/elasticsearch/config/certs/ (transport TLS used
#    them). HTTP TLS reuses the same paths.
#
# 2. cookbooks/lxc-kibana/default.rb requires NO change IF Phase 3b already
#    fetches /monitoring/elastic/ca/cert from SSM and installs to
#    /usr/share/kibana/config/certs/ca.crt (mounted into the kibana
#    container at the same path). If Phase 3b did NOT do this — because
#    HTTP TLS was deferred — add a `remote_file`-style resource that fetches
#    the SSM CA cert and installs it to the kibana data dir before the
#    container's compose up. Match the pattern Phase 3b uses for ES nodes.
#
# 3. cookbooks/lxc-monitoring/files/vector.toml: no change. Phase 4 already
#    shipped tls.verify_certificate = true + verify_hostname = true on the
#    Vector ES sink. Those settings are no-ops while ES HTTP is plain; they
#    become effective the moment this patch's ES side flips on.
#
# 4. Kibana's own browser-facing HTTPS (server.ssl.enabled) is intentionally
#    deferred to a follow-up PR. This patch covers ES ↔ {Vector, Kibana}
#    only — i.e., the LAN-internal control + data plane.
#
# 5. Rolling apply procedure (per phase-7-http-tls.md):
#      mitamae apply on es-0 → wait cluster green → es-1 → green → es-2 → green → kibana
#    Cluster yellow is expected during each node's restart window (replicas
#    temporarily unassigned). Green is the gate.
