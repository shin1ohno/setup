#
# Apply with: git apply docs/adr/0005-impl/phase-7-s3-cookbook.patch
#
# Prerequisites:
#   - Phase 3b merged (cookbooks/lxc-elasticsearch/default.rb exists on main)
#   - Phase 7-s3-tf merged (SSM /monitoring/elastic/s3-snapshot/* + IAM exists)
#   - This branch rebased onto updated main
#
# The patch below is a structural diff. Fence-line offsets in the existing
# file may differ slightly after Phase 3b lands; if `git apply` fails with
# "patch does not apply", use `git apply --3way` or hand-merge the additions.
# All the additions are append-only (new resources at the end of the
# cookbook + a new file under cookbooks/lxc-elasticsearch/files/), so a 3-way
# merge should resolve cleanly in every case.

diff --git a/cookbooks/lxc-elasticsearch/default.rb b/cookbooks/lxc-elasticsearch/default.rb
--- a/cookbooks/lxc-elasticsearch/default.rb
+++ b/cookbooks/lxc-elasticsearch/default.rb
@@ -- ANCHOR: place at end of file, after existing Phase 3b resources --
+
+# ---------------------------------------------------------------------------
+# Phase 7-s3 — S3 snapshot repository + SLM daily policy
+# ---------------------------------------------------------------------------
+#
+# Closes ADR 0005 §否定面 #4 (disk SPOF — 3 ES ノード全て同一 USB SSD に
+# bind-mount). The X8 USB SSD physical fragility (cable-out → 3 disks lost
+# simultaneously) is outside ES HA's protection model; daily S3 snapshots
+# provide off-site backup.
+#
+# Companion: home-monitor branch `feat/adr0005-phase7-s3-snapshot` creates:
+#   - aws_s3_bucket: home-monitor-elasticsearch-snapshots-<account>
+#   - aws_iam_user: elasticsearch-snapshot (with bucket read/write policy)
+#   - aws_ssm_parameter: /monitoring/elastic/s3-snapshot/{access-key-id,secret-access-key,bucket-name}
+#   - pve-bootstrap-ssm IAM policy extension: ssm:GetParameter on /monitoring/elastic/s3-snapshot/*
+#
+# Idempotency strategy:
+#   - SSM fetch + keystore add: gated by sha256 sentinel
+#     (/var/lib/elasticsearch/.s3-keystore-hash) — re-runs only when SSM
+#     value rotated
+#   - reload_secure_settings: notify-driven from keystore add
+#   - snapshot repo PUT: gated by GET .../_status returning 200
+#   - SLM policy PUT: gated by GET .../_slm/policy/daily-snapshot returning 200
+#
+# Node gating: keystore add runs on ALL nodes (the secret must exist in every
+# node's keystore for snapshot writes to succeed from any master). Repo + SLM
+# registration runs on es-0 only (cluster-wide state, single-node sufficient).
+
+s3_snapshot_state_dir = "/var/lib/elasticsearch"
+s3_snapshot_sentinel  = "#{s3_snapshot_state_dir}/.s3-keystore-hash"
+s3_snapshot_script    = "/usr/local/bin/elasticsearch-snapshot-bootstrap"
+
+# Stage the bootstrap script. Mode 700, root-owned — script reads SSM
+# (decrypts SecureString) and pipes secrets into docker exec stdin.
+remote_file s3_snapshot_script do
+  source "files/snapshot-bootstrap.sh"
+  owner "root"
+  group "root"
+  mode "700"
+end
+
+# Phase 7-s3 — fetch S3 snapshot creds + add to keystore on every node.
+# The keystore-add step inside the bootstrap script is internally idempotent
+# (sentinel hash check before re-add). The cookbook resource itself is also
+# guarded by `only_if` reading the sentinel, so a "no-op" mitamae run that
+# matches the SSM value does NOT shell out to the script at all.
+require_external_auth(
+  tool_name: "AWS CLI (profile=#{aws_profile}, region=#{aws_region}) for /monitoring/elastic/s3-snapshot/*",
+  check_command: "aws ssm get-parameter --name /monitoring/elastic/s3-snapshot/access-key-id " \
+                 "--with-decryption --profile #{aws_profile} --region #{aws_region} " \
+                 "> /dev/null 2>&1",
+  instructions: "Configure '#{aws_profile}' with ssm:GetParameter on " \
+                "/monitoring/elastic/s3-snapshot/* in #{aws_region}. " \
+                "Phase 7-s3-tf creates these SSM parameters; ensure that " \
+                "branch is merged and applied before this cookbook runs.",
+  skip_if: -> { !File.exist?(s3_snapshot_script) },
+) do
+  execute "elasticsearch-snapshot: fetch + keystore add" do
+    command "AWS_PROFILE=#{aws_profile} AWS_REGION=#{aws_region} " \
+            "#{s3_snapshot_script} keystore-add"
+    user "root"
+    notifies :run, "execute[elasticsearch-snapshot: reload secure settings]"
+  end
+end
+
+# Reload secure settings on the local node after keystore add. Cluster-wide
+# fan-out happens automatically — the local POST triggers ES master
+# coordination. action :nothing → fires only when keystore add ran.
+execute "elasticsearch-snapshot: reload secure settings" do
+  command "#{s3_snapshot_script} reload-secure-settings"
+  user "root"
+  action :nothing
+  # If we get here via notify, run on every node (keystore was just changed
+  # on this node, the cluster needs to know).
+  if node[:elasticsearch] && node[:elasticsearch][:node_name] == "es-0"
+    notifies :run, "execute[elasticsearch-snapshot: register repository]"
+    notifies :run, "execute[elasticsearch-snapshot: register SLM policy]"
+  end
+end
+
+# Register the snapshot repository (es-0 only — cluster-wide state).
+# Idempotent: skipped when GET /_snapshot/s3-home-monitor/_status returns 200.
+execute "elasticsearch-snapshot: register repository" do
+  command "#{s3_snapshot_script} register-repo"
+  user "root"
+  action :nothing
+  only_if { node[:elasticsearch] && node[:elasticsearch][:node_name] == "es-0" }
+end
+
+# Initial-converge entry: register repo on first apply if not yet present
+# (keystore reload may have completed but repo never registered).
+execute "elasticsearch-snapshot: ensure repository registered" do
+  command "#{s3_snapshot_script} register-repo"
+  user "root"
+  only_if { node[:elasticsearch] && node[:elasticsearch][:node_name] == "es-0" }
+  not_if  "#{s3_snapshot_script} repo-exists"
+end
+
+# Register / update SLM policy (es-0 only). Idempotent at the script level
+# via GET-policy comparison.
+execute "elasticsearch-snapshot: register SLM policy" do
+  command "#{s3_snapshot_script} register-slm"
+  user "root"
+  action :nothing
+  only_if { node[:elasticsearch] && node[:elasticsearch][:node_name] == "es-0" }
+end
+
+# Initial-converge entry: register SLM policy on first apply.
+execute "elasticsearch-snapshot: ensure SLM policy registered" do
+  command "#{s3_snapshot_script} register-slm"
+  user "root"
+  only_if { node[:elasticsearch] && node[:elasticsearch][:node_name] == "es-0" }
+  not_if  "#{s3_snapshot_script} slm-exists"
+end

diff --git a/cookbooks/lxc-elasticsearch/files/snapshot-bootstrap.sh b/cookbooks/lxc-elasticsearch/files/snapshot-bootstrap.sh
new file mode 100755
--- /dev/null
+++ b/cookbooks/lxc-elasticsearch/files/snapshot-bootstrap.sh
@@ -0,0 +1,196 @@
+#!/usr/bin/env bash
+# Phase 7-s3 — Elasticsearch S3 snapshot bootstrap.
+#
+# Subcommands:
+#   keystore-add             Fetch S3 creds from SSM, hash-compare against
+#                            sentinel, re-add to ES keystore if changed.
+#   reload-secure-settings   POST /_nodes/reload_secure_settings on local node
+#                            (cluster fan-out is automatic).
+#   register-repo            PUT /_snapshot/s3-home-monitor (idempotent).
+#   repo-exists              Exit 0 if repo already registered.
+#   register-slm             PUT /_slm/policy/daily-snapshot (idempotent).
+#   slm-exists               Exit 0 if SLM policy already registered.
+#
+# Env (passed by mitamae execute):
+#   AWS_PROFILE, AWS_REGION
+#
+# Reads ELASTIC_PASSWORD from /etc/elasticsearch/.env (placed by Phase 3b
+# cookbook). All curl calls hit https://localhost:9200 with -k (self-signed
+# node cert from Phase 3b TLS bootstrap).
+
+set -euo pipefail
+
+CONTAINER_NAME="${ES_CONTAINER_NAME:-elasticsearch}"
+ENV_FILE="${ES_ENV_FILE:-/etc/elasticsearch/.env}"
+SENTINEL="/var/lib/elasticsearch/.s3-keystore-hash"
+REPO_NAME="s3-home-monitor"
+SLM_POLICY="daily-snapshot"
+ES_URL="${ES_URL:-https://localhost:9200}"
+
+SSM_ACCESS_KEY_PATH="/monitoring/elastic/s3-snapshot/access-key-id"
+SSM_SECRET_KEY_PATH="/monitoring/elastic/s3-snapshot/secret-access-key"
+SSM_BUCKET_PATH="/monitoring/elastic/s3-snapshot/bucket-name"
+
+# shellcheck disable=SC1090
+. "${ENV_FILE}"
+: "${ELASTIC_PASSWORD:?ELASTIC_PASSWORD missing from ${ENV_FILE}}"
+
+ssm_get() {
+  aws ssm get-parameter --name "$1" --with-decryption \
+    --profile "${AWS_PROFILE}" --region "${AWS_REGION}" \
+    --output text --query 'Parameter.Value'
+}
+
+es_curl() {
+  curl -fsS -k -u "elastic:${ELASTIC_PASSWORD}" "$@"
+}
+
+es_curl_status() {
+  curl -s -k -o /dev/null -w '%{http_code}' \
+    -u "elastic:${ELASTIC_PASSWORD}" "$@"
+}
+
+cmd_keystore_add() {
+  local access_key secret_key bucket combined hash
+
+  access_key=$(ssm_get "${SSM_ACCESS_KEY_PATH}")
+  secret_key=$(ssm_get "${SSM_SECRET_KEY_PATH}")
+  bucket=$(ssm_get "${SSM_BUCKET_PATH}")
+
+  # Hash all three together so any rotation re-triggers.
+  combined="${access_key}|${secret_key}|${bucket}"
+  hash=$(printf '%s' "${combined}" | openssl dgst -sha256 | awk '{print $2}')
+
+  if [[ -f "${SENTINEL}" ]] && [[ "$(cat "${SENTINEL}")" == "${hash}" ]]; then
+    echo "[s3-snapshot] keystore in sync (hash matches sentinel) — skipping"
+    return 0
+  fi
+
+  echo "[s3-snapshot] adding S3 access key to ES keystore"
+  printf '%s' "${access_key}" | docker exec -i "${CONTAINER_NAME}" \
+    bin/elasticsearch-keystore add --stdin --force s3.client.default.access_key
+
+  echo "[s3-snapshot] adding S3 secret key to ES keystore"
+  printf '%s' "${secret_key}" | docker exec -i "${CONTAINER_NAME}" \
+    bin/elasticsearch-keystore add --stdin --force s3.client.default.secret_key
+
+  # Persist bucket name for downstream subcommands.
+  install -d -m 700 -o root -g root /var/lib/elasticsearch
+  printf '%s' "${bucket}" > /var/lib/elasticsearch/.s3-bucket
+  chmod 600 /var/lib/elasticsearch/.s3-bucket
+
+  printf '%s' "${hash}" > "${SENTINEL}"
+  chmod 600 "${SENTINEL}"
+
+  echo "[s3-snapshot] keystore add complete; sentinel updated"
+}
+
+cmd_reload_secure_settings() {
+  echo "[s3-snapshot] reloading secure settings (local node)"
+  es_curl -X POST "${ES_URL}/_nodes/reload_secure_settings" \
+    -H 'Content-Type: application/json' \
+    -d '{"secure_settings_password":""}' >/dev/null
+  echo "[s3-snapshot] reload OK"
+}
+
+cmd_repo_exists() {
+  local status
+  status=$(es_curl_status "${ES_URL}/_snapshot/${REPO_NAME}/_status" || true)
+  [[ "${status}" == "200" ]]
+}
+
+cmd_register_repo() {
+  local bucket
+
+  if [[ ! -f /var/lib/elasticsearch/.s3-bucket ]]; then
+    echo "[s3-snapshot] ERROR: bucket name not staged; run keystore-add first" >&2
+    exit 1
+  fi
+  bucket=$(cat /var/lib/elasticsearch/.s3-bucket)
+
+  if cmd_repo_exists; then
+    echo "[s3-snapshot] repo ${REPO_NAME} already registered — skipping"
+    return 0
+  fi
+
+  echo "[s3-snapshot] registering snapshot repo ${REPO_NAME} (bucket=${bucket})"
+  es_curl -X PUT "${ES_URL}/_snapshot/${REPO_NAME}" \
+    -H 'Content-Type: application/json' \
+    -d @- >/dev/null <<EOF
+{
+  "type": "s3",
+  "settings": {
+    "bucket": "${bucket}",
+    "base_path": "snapshots/home-monitor-rtx",
+    "client": "default",
+    "compress": true
+  }
+}
+EOF
+  echo "[s3-snapshot] repo registered"
+}
+
+cmd_slm_exists() {
+  local status
+  status=$(es_curl_status "${ES_URL}/_slm/policy/${SLM_POLICY}" || true)
+  [[ "${status}" == "200" ]]
+}
+
+cmd_register_slm() {
+  if cmd_slm_exists; then
+    # Even if it exists, PUT to update (idempotent on stable input — ES will
+    # accept the same policy without changes). We still skip to avoid log
+    # noise on every apply; uncomment to force-update.
+    echo "[s3-snapshot] SLM ${SLM_POLICY} already exists — skipping"
+    return 0
+  fi
+
+  echo "[s3-snapshot] registering SLM policy ${SLM_POLICY}"
+  es_curl -X PUT "${ES_URL}/_slm/policy/${SLM_POLICY}" \
+    -H 'Content-Type: application/json' \
+    -d @- >/dev/null <<'EOF'
+{
+  "schedule": "0 30 1 * * ?",
+  "name": "<daily-snap-{now/d}>",
+  "repository": "s3-home-monitor",
+  "config": {
+    "indices": ["logs-rtx-*"],
+    "include_global_state": false,
+    "ignore_unavailable": true
+  },
+  "retention": {
+    "expire_after": "30d",
+    "min_count": 7,
+    "max_count": 30
+  }
+}
+EOF
+  echo "[s3-snapshot] SLM policy registered"
+}
+
+main() {
+  case "${1:-}" in
+    keystore-add)            cmd_keystore_add ;;
+    reload-secure-settings)  cmd_reload_secure_settings ;;
+    register-repo)           cmd_register_repo ;;
+    repo-exists)             cmd_repo_exists ;;
+    register-slm)            cmd_register_slm ;;
+    slm-exists)              cmd_slm_exists ;;
+    *)
+      echo "usage: $0 {keystore-add|reload-secure-settings|register-repo|repo-exists|register-slm|slm-exists}" >&2
+      exit 64
+      ;;
+  esac
+}
+
+main "$@"
